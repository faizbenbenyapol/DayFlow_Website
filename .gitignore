# ==========================================
# DayFlow Website - Git Ignore Settings
# Designed for Public Repository
# ==========================================

# --- System & OS Files ---
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# --- IDEs & Editors ---
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# --- LLM & Agent Temporary Directories ---
.antigravity/
.claude/

# --- Environment and Sensitive Configuration ---
# Ignore the auto-generated application encryption key (VERY IMPORTANT for public repos)
/config/.app_key
# config/config.php is intentionally tracked: it contains only safe defaults.
# Put real credentials in .env (which remains ignored).
/storage/logs/*
!/storage/logs/.gitkeep
/storage/ratelimit/*
!/storage/ratelimit/.gitkeep
/backups/*
!/backups/.gitkeep

# Ignore any local environment files or backups
.env
.env.local
.env.*.local
*.env
*.bak
*.config
client_secret*.json
*service-account*.json
credentials*.json
*.pem
*.key
*.p12
*.pfx
*.crt

# --- Uploads and User Assets ---
# Ignore all uploaded files, but keep the directory and security .htaccess file
/uploads/*
!/uploads/.htaccess

# --- Database & SQL Backups ---
# Ignore database dumps, but keep application migrations public because the
# Docker image and migration runner need them on a fresh server.
*.sql
!/sql/
!/sql/**/*.sql
!/sql/*.sql

# --- Server Logs & Caches ---
*.log
error_log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
