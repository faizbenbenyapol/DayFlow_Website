Options -Indexes

# Enable rewrite engine
RewriteEngine On

# Block direct access to sensitive directories
RewriteRule ^config(/|$) - [F,L]
RewriteRule ^core(/|$) - [F,L]
RewriteRule ^models(/|$) - [F,L]
RewriteRule ^controllers(/|$) - [F,L]
RewriteRule ^sql(/|$) - [F,L]
RewriteRule ^views(/|$) - [F,L]
RewriteRule ^install(/|$) - [F,L]
RewriteRule ^config/.*\.php$ - [F,L]

# Allow access to assets and uploads directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Route everything else through index.php
RewriteRule ^ index.php [QSA,L]

# Security headers are emitted by core/Security.php to avoid duplicate values.

# Static asset caching. Query-string filemtime versions are already used by
# the templates, so immutable caching is safe for these files.
<IfModule mod_headers.c>
    <FilesMatch "\.(css|js|png|jpg|jpeg|gif|webp|svg|ico|woff2)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>

# PHP settings (if mod_php)
<IfModule mod_php7.c>
    php_value upload_max_filesize 20M
    php_value post_max_size 22M
    php_value max_execution_time 60
</IfModule>
<IfModule mod_php8.c>
    php_value upload_max_filesize 20M
    php_value post_max_size 22M
    php_value max_execution_time 60
</IfModule>
